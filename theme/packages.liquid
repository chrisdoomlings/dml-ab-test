{% comment %} Home page section {% endcomment %}
{% schema %}
  {
    "name": "Packages",
    "max_blocks": 4,
    "settings": [
      { 
        "type": "header",
        "content": "Section Settings"
      },
      {
        "type": "text",
        "id": "section_title",
        "label": "Section Title",
        "default": "Get Started"
      },
      {
        "type": "header",
        "content": "Spacing"
      },
      {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "Padding Top",
        "default": 36
      },
      {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "Padding Bottom",
        "default": 36
      }
    ],
    "blocks": [
      {
        "type": "package",
        "name": "Package",
        "settings": [
          {
            "type": "header",
            "content": "Package Content"
          },
          {
            "type": "text",
            "id": "package_title",
            "label": "Package Title",
            "default": "Package Title"
          },
          {
            "type": "image_picker",
            "id": "product_image",
            "label": "Product Image"
          },
          {
            "type": "image_picker",
            "id": "product_image_b",
            "label": "Product Image — Variant B (A/B test)"
          },
          {
            "type": "checkbox",
            "id": "ab_test_enable",
            "label": "Enable image A/B test on this block",
            "default": false,
            "info": "Only enable on ONE block at a time. Leave blank on all others."
          },
          {
            "type": "product",
            "id": "product_link",
            "label": "Select Product"
          },
          {
            "type": "html",
            "id": "product_details",
            "label": "Product Details"
          },
          {
            "type": "header",
            "content": "Pricing Options"
          },
          {
            "type": "header",
            "content": "Color Settings"
          },
          {
            "type": "color",
            "id": "sale_price_color",
            "label": "Sale Price Color",
            "default": "#b5001a"
          },
          {
            "type": "color",
            "id": "compare_price_color",
            "label": "Compare Price Color",
            "default": "#1a0040"
          },  
          {
            "type": "color",
            "id": "value_price_color",
            "label": "Value Price Color",
            "default": "#00bd3e"
          },          
          {
            "type": "checkbox",
            "id": "price_sale_enable",
            "label": "Enable Sale Price",
            "info": "Shows slashed out price from dummy product",
            "default": false
          },
          {
            "type": "product",
            "id": "product_linkcompare",
            "label": "Select Sale Price Dummy Product",
            "info": "This product selection is only for price comparison"
          },
          {
            "type": "checkbox",
            "id": "price_adj_enable",
            "label": "Enable Value Price",
            "default": false,
            "info": "Shows product compare-at price"
          },
          {
            "type": "header",
            "content": "Value Header"
          },
          {
            "type": "checkbox",
            "id": "enable_value_header",
            "label": "Enable Value Header"
          },
          {
            "type": "text",
            "id": "value_header_text",
            "label": "Value Header Text"
          },
          {
            "type": "image_picker",
            "id": "value_icon",
            "label": "Value Icon"
          },
          {
            "type": "color",
            "id": "header_bg_color",
            "label": "Value Header Background Color",
            "default": "#50248f"
          },
          {
            "type": "header",
            "content": "Package Design"
          },
          {
            "type": "image_picker",
            "id": "border_image",
            "label": "Background Image",
            "info": "Upload an image to use as the background for this package."
          },
          {
            "type": "color",
            "id": "border_color",
            "label": "Border Color",
            "default": "#50248f"
          },
          {
            "type": "header",
            "content": "Call to Action"
          },
          {
            "type": "text",
            "id": "btn_text",
            "label": "Button Text",
            "default": "Order Now"
          }  
        ]
      }
    ],
    "presets": [
      {
        "category": "section",
        "name": "Packages"
      }
    ]
  }
  {% endschema %}
  
  <style>
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
  
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  
    #shopify-section-{{section.id}} .packages-wrapper {  
      display: grid;
      grid-template-columns: repeat(4, minmax(250px, 1fr));
      gap: 20px;
      width: 100%;
      margin: 0 auto;
      justify-content: center;  
    }
  
    #shopify-section-{{section.id}} .package {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      align-items: center;
      box-sizing: border-box;  
      margin: 20px 0;
      padding: 20px 30px 40px 35px;
      border-radius: 8px;
      position: relative;
      width: 100%;
      min-height: 400px;
    }
  
    .package[style*="background-image"] {
      padding: 0 35px 25px 35px;
    }
  
    @media (min-width: 768px) {
      #shopify-section-{{section.id}} .package {
        min-height: 800px;
      }
    }
  
    #shopify-section-{{section.id}} .section_title {
      text-align: center;
      font-family: 'Anton', sans-serif;
      text-transform: uppercase;
      font-size: 40px;
      letter-spacing: 1px;
    }
    @media (max-width: 749px) {
      #shopify-section-{{section.id}} .section_title {
        font-size: 32px;
      }
    }
      
    #shopify-section-{{section.id}} .prod-list {
      padding-bottom: 20px;
      font-weight: 700;
    }
    #shopify-section-{{section.id}} .prod-outer { text-align:center; }  
    @media (min-width:768px){
      #shopify-section-{{section.id}} .prod-outer { min-height:53px; }
    }  
  
    #shopify-section-{{section.id}} .prod-list ul li {
      display: flex;
    }
  
    #shopify-section-{{section.id}} .prod-list ul li span {
      font-size: 10px;
    }
  
    #shopify-section-{{section.id}} .packages-container h3.prod-title {  
      font-size: 28px;
      text-transform: uppercase;
      color: #230051;
      text-align: center;
      letter-spacing: .5px;
      padding-top:12px;
    }
  
    #shopify-section-{{section.id}} .packages-container .prod-price { 
      /*display: flex;*/
      flex-wrap: wrap;
      justify-content: center;
      align-items: flex-end;
      margin-top: 10px;
      align-content: center;
      min-height: 60px;
    }
  
    #shopify-section-{{section.id}} .packages-container .prod-price span { display:block; }
    #shopify-section-{{section.id}} .packages-container .prod-price span span { display:inline-block; }
  
    #shopify-section-{{section.id}} .packages-container .sale_price,
    #shopify-section-{{section.id}} .packages-container .value_price,  
    #shopify-section-{{section.id}} .packages-container .compare-price {
      font-family: 'Lato', sans-serif;
      display: flex;
    }
  
    #shopify-section-{{section.id}} .packages-container .sale_price,
    #shopify-section-{{section.id}} .packages-container .compare-price {
      font-weight: 600;
      font-size: 24px;
      line-height: 24px;
      margin-right: 5px;
    }
  
    #shopify-section-{{section.id}} .packages-container .value_price {
      font-size: 15px;  
      font-weight: bold;
      line-height: 16px;
      margin-bottom: 4px;
    }
  
    #shopify-section-{{ section.id }} .packages-container .sale_price {
      color: var(--sale-price-color, #b5001a);
      font-weight: bold;
    }
  
    #shopify-section-{{ section.id }} .compare-price {
      position: relative;
      color: var(--compare-price-color, #1a0040);
      font-weight: bold;
    }
  #shopify-section-{{ section.id }} .value-price-container .value_price{color:#19ae2c}
    #shopify-section-{{ section.id }} .compare-price::before {
      content: "";
      position: absolute;
      width: 100%;
      height: 3px;
      background-color: #b5001a;
      top: 50%;
      left: 0;
      transform: rotate(-8deg);
      transform-origin: center;
    }
  
    #shopify-section-{{section.id}} .do-hr-wrapper {
      display: flex;
      justify-content: center;
    }
  
    #shopify-section-{{section.id}} hr.do-hr {
      display: block;
      width: 120px;
      border-top: 3px solid #50248f;
      margin: 0 0 16px;
    }
  
    #shopify-section-{{section.id}} .value-header-wrapper {
      position: absolute;
      top: -25px;
      left: 50%;
      transform: translateX(-50%);
      width: 90%;
      max-width: 240px;
      z-index: 10;
    }
    .package[style*="background-image"] .value-header-wrapper {
      top: -20px;
    }
  
    #shopify-section-{{section.id}} .value-header {
      color: white;
      text-transform: uppercase;
      border-radius: 8px;
      padding: 10px 30px;
      position: relative;
      text-align: center;
      font-size: 20px;
      font-weight: 900;  
      background: var(--header-bg-color, #50248f);
    }
  
    #shopify-section-{{section.id}} .value-header span {
      position: absolute;
      left: -15px;
      top: -13px;
      display: block;
    }
  
    #shopify-section-{{section.id}} .value-header img {
      max-width: 44px;
      width: 100%;
      height: auto;
      object-fit: contain;
    }
  
    .yotpo .text-m {
      padding-left: 5px;  
    }
  
    .yotpo-sr-bottom-line-text {
      cursor: pointer;
    }
  
    #shopify-section-{{section.id}} sup {
      top: 8px;
    }
  
    #shopify-section-{{section.id}} .product-image img {
      width: 100%;
      height: auto;
      object-fit: contain;
      padding-top: 0; 
    }
    .package[style*="background-image"] .product-image img {
      max-width: 94%;
      padding-top: 16px;
    }
  
    @media screen and (max-width: 1024px) {
      #shopify-section-{{section.id}} .packages-wrapper {
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
        padding: 0 15px;
      }
  
      #shopify-section-{{section.id}} .package {
        margin: 15px 0;
      }
    }
  
    @media screen and (max-width: 749px) {
      #shopify-section-{{section.id}} .packages-wrapper {
        grid-template-columns: 1fr;
        gap: 30px;
        padding: 0 10px;
      }
  
      #shopify-section-{{section.id}} .package {
        margin: 10px 0;
      }
  
      #shopify-section-{{section.id}} .prod-link {  
        text-align: center;  
        margin-top: 20px;  
      }
  
      #shopify-section-{{section.id}} .prod-list {
        display: flex;
        justify-content: center;  
        margin-top: 15px;
      }
    }
  
    {% for block in section.blocks %}
      #shopify-section-{{section.id}} .package-{{ block.id }} {
        --sale-price-color: {{ block.settings.sale_price_color }};
        --compare-price-color: {{ block.settings.compare_price_color }};
        --value-price-color: {{ block.settings.value_price_color }};
        --header-bg-color: {{ block.settings.header_bg_color }};
      }
      {% if block.settings.border_image == blank %}
        #shopify-section-{{section.id}} .package-{{ block.id }} {
          border: 5px solid {{ block.settings.border_color }};
        }
      {% endif %}
    {% endfor %}
  </style>
  
  {%- assign dml_ab_enabled_count = 0 -%}
  {%- assign dml_ab_active_title = "" -%}
  {%- for block in section.blocks -%}
    {%- if block.settings.ab_test_enable -%}
      {%- assign dml_ab_enabled_count = dml_ab_enabled_count | plus: 1 -%}
      {%- assign dml_ab_active_title = block.settings.package_title -%}
    {%- endif -%}
  {%- endfor -%}
  
  {%- if dml_ab_enabled_count > 1 -%}
    <div style="background:#c40000;color:#fff;padding:14px 20px;margin-bottom:12px;border-radius:6px;font-weight:700;font-size:14px;text-align:center;">
      ⚠️ DML A/B Test conflict — {{ dml_ab_enabled_count }} blocks have the image test enabled. Only ONE block should be active at a time. Disable the others in Theme Customizer.
    </div>
  {%- endif -%}
  
  <div class="container large-section packages-container section-{{ section.id }}-padding">
    <div class="page-width">
      <h2 id="sectionTitle" class="section_title">{{ section.settings.section_title }}</h2>
      <div class="packages-wrapper" aria-labelledby="sectionTitle">
        {% for block in section.blocks %}
          {% assign product = all_products[block.settings.product_link] %}
          {% assign compare_product = all_products[block.settings.product_linkcompare] %}
          <div class="package package-{{ block.id }}" tabindex="0"
            style="
              {% if block.settings.border_image %}
                background-image: url({{ block.settings.border_image | img_url: 'original' }});
                background-size: 99% 100%;
                background-position: center;
                background-repeat: no-repeat;
              {% endif %}
            ">
            <div class="products-game-opt">
              <div class="game-opt-prod">
                {% if block.settings.enable_value_header %}    
                  <div class="value-header-wrapper" aria-hidden="true">
                    <div class="value-header">  
                      {% if block.settings.value_icon %}            
                        <span class="value-icon-wrapper">            
                          <img 
                            alt="{{ block.settings.value_icon.alt | escape | default: 'Card game value icon' }}"
                            width="{{ block.settings.value_icon.width | default: 50 }}"
                            height="{{ block.settings.value_icon.height | default: 50 }}"
                            loading="lazy"
                            src="{{ block.settings.value_icon | img_url: '50x50', crop: 'center' }}"
                            srcset="{{ block.settings.value_icon | img_url: '50x50', crop: 'center' }} 1x,
                                    {{ block.settings.value_icon | img_url: '100x100', crop: 'center' }} 2x"
                            style="object-fit: contain; aspect-ratio: {{ block.settings.value_icon.width | default: 50 }} / {{ block.settings.value_icon.height | default: 50 }};"
                          >
                        </span>
                      {% endif %}
                      {{ block.settings.value_header_text }}
                    </div>
                  </div>
                {% endif %}  
                {% if block.settings.product_image %}
                  <a href="{{ product.url }}" class="product-image" aria-label="View {{ block.settings.package_title }}">
                    {% if block.settings.ab_test_enable %}
                      <img
                        id="dml-img-a"
                        alt="{{ block.settings.product_image.alt | escape }}"
                        width="{{ block.settings.product_image.width | default: 600 }}"
                        height="{{ block.settings.product_image.height | default: 600 }}"
                        loading="lazy"
                        src="{{ block.settings.product_image | img_url: '300x' }}"
                        srcset="{{ block.settings.product_image | img_url: '300x' }} 300w,
                                      {{ block.settings.product_image | img_url: '600x' }} 600w"
                        sizes="(max-width: 768px) 300px, 600px"
                        style="aspect-ratio: {{ block.settings.product_image.width | default: 600 }} / {{ block.settings.product_image.height | default: 600 }};"
                      >
                      {% if block.settings.product_image_b %}
                        <img
                          id="dml-img-b"
                          alt="{{ block.settings.product_image_b.alt | escape }}"
                          width="{{ block.settings.product_image_b.width | default: 600 }}"
                          height="{{ block.settings.product_image_b.height | default: 600 }}"
                          loading="lazy"
                          src="{{ block.settings.product_image_b | img_url: '300x' }}"
                          srcset="{{ block.settings.product_image_b | img_url: '300x' }} 300w,
                                        {{ block.settings.product_image_b | img_url: '600x' }} 600w"
                          sizes="(max-width: 768px) 300px, 600px"
                          style="display:none;aspect-ratio: {{ block.settings.product_image_b.width | default: 600 }} / {{ block.settings.product_image_b.height | default: 600 }};"
                        >
                      {% endif %}
                    {% else %}
                      <img
                        alt="{{ block.settings.product_image.alt | escape }}"
                        width="{{ block.settings.product_image.width | default: 600 }}"
                        height="{{ block.settings.product_image.height | default: 600 }}"
                        loading="lazy"
                        src="{{ block.settings.product_image | img_url: '300x' }}"
                        srcset="{{ block.settings.product_image | img_url: '300x' }} 300w,
                                      {{ block.settings.product_image | img_url: '600x' }} 600w"
                        sizes="(max-width: 768px) 300px, 600px"
                        style="aspect-ratio: {{ block.settings.product_image.width | default: 600 }} / {{ block.settings.product_image.height | default: 600 }};"
                      >
                    {% endif %}
                  </a>
                {% endif %}
  
                <div class="product-info">
                  <h3 class="prod-title">{{ block.settings.package_title }}</h3>
                  <div class="prod-outer">
                    <div class="prod-price">
                      <span class="price-container">
                        <span class="sale_price">{{ product.price | money }}</span>
                        {% if block.settings.price_sale_enable %}
                          <span class="compare-price">{{ compare_product.price | money }}</span>
                        {% endif %}
                      </span>
                      {% if block.settings.price_adj_enable and product.compare_at_price %}
                      <span class="value-price-container">
                        <span class="value_price">
                          {{ product.compare_at_price | money | remove: '.00' }}&nbsp;value!
                        </span>
                      </span>
                      {% endif %}
                    </div>
                  </div>
                  <div class="doomlings-review-count-placeholder" style="min-height: 20px; margin: 10px 0;">
                    <a href="{{ product.url }}#doomlings-reviews" class="doomlings-review-link" aria-label="Read reviews for {{ block.settings.package_title }}">
                      <div
                        class="doomlings-review-count-anchor"
                        data-product-id="{{ product.id }}"
                        data-product-handle="{{ product.handle }}"
                        data-product-url="{{ product.url }}"
                      ></div>
                    </a>
                  </div>
                  <div class="prod-list">
                    <ul>{{ block.settings.product_details }}</ul>
                  </div>
                </div>
              </div>
            </div>
            <div class="prod-link">
              <a class="do-btn" href="{{ product.url }}" aria-label="View more about {{ block.settings.package_title }}">{{ block.settings.btn_text }}</a>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
  
  <script type="text/javascript">
    document.addEventListener('DOMContentLoaded', function () {
      var userLanguage = navigator.language || navigator.userLanguage;  
      var freeShippingCountries = ['en-US', 'en-GB', 'en-CA', 'de-DE', 'nl-NL'];
  
      var deluxeShipping = document.getElementById('deluxe-free-shipping');
      if (deluxeShipping && userLanguage === 'en-US') {
        deluxeShipping.style.display = 'block';
      }
  
      var ultimateShipping = document.getElementById('ultimate-free-shipping');
      if (ultimateShipping && freeShippingCountries.includes(userLanguage)) {
        ultimateShipping.style.display = 'block';
      }
    });
  </script>