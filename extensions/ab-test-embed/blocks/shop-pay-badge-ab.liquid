{%- assign selected_variant = product.selected_or_first_available_variant -%}
{%- assign variant_price = selected_variant.price | default: 0 -%}
{%- assign installments = block.settings.installments | default: 4 -%}

{%- if product -%}

  {{- '#dml-badge-a,#dml-badge-b{display:none}' | prepend: '<style>' | append: '</style>' -}}

  <!-- Control (A): empty placeholder — nothing visible -->
  <div id="dml-badge-a" aria-hidden="true"></div>

  <!-- Variant (B): Shop Pay installments badge -->
  <div
    id="dml-badge-b"
    data-installments="{{ installments }}"
    data-money-format="{{ shop.money_format | escape }}"
    data-initial-price="{{ variant_price }}"
    style="padding:10px 0;color:{{ block.settings.text_color }};font-size:{{ block.settings.font_size }}px;line-height:1.5;"
    {{ block.shopify_attributes }}
  >
    <svg width="16" height="11" viewBox="0 0 38 14" fill="none" xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true" style="vertical-align:middle;margin-right:5px;flex-shrink:0;">
      <path d="M6.76 0C4.36 0 2.4 1.54 2.4 3.44c0 1.6 1.14 2.68 3.02 3.16l1.66.42c1.04.26 1.52.68 1.52 1.32 0 .76-.78 1.28-1.92 1.28-1.24 0-2.08-.6-2.22-1.6H2.1C2.28 10.18 4.1 11.6 6.7 11.6c2.54 0 4.4-1.44 4.4-3.46 0-1.62-1.06-2.72-3.1-3.22L6.34 4.5c-1-.26-1.46-.64-1.46-1.24 0-.72.72-1.22 1.82-1.22 1.14 0 1.88.58 2.02 1.52h2.3C10.82 1.38 9.1 0 6.76 0zm8.78.18L12.2 11.42h2.44l.66-2.2h3.56l.66 2.2h2.44L18.6.18h-3.06zm1.52 2.08l1.28 4.98h-2.54l1.26-4.98zm7.14-2.08v11.24H26.6V7.18h2.52c2.56 0 4.14-1.42 4.14-3.52S31.66.18 29.12.18h-4.92zm2.4 1.94h2.28c1.1 0 1.76.6 1.76 1.58 0 .98-.66 1.56-1.76 1.56H26.6V2.12zm8.84-1.94v11.24H38V.18h-2.56z"
        fill="{{ block.settings.icon_color }}"/>
    </svg>
    Available in <strong>{{ installments }}</strong> monthly payments of
    <strong class="dml-badge-install-price">{{ variant_price | divided_by: installments | money }}</strong>
    through <strong>Shop Pay Installments</strong>
  </div>

  <script>
  (function () {
    var badge = document.getElementById('dml-badge-b');
    if (!badge) return;

    var installments = parseInt(badge.dataset.installments, 10) || 4;
    var moneyFormat = badge.dataset.moneyFormat || '${{amount}}';
    var priceEl = badge.querySelector('.dml-badge-install-price');

    function formatMoney(cents) {
      var amount = cents / 100 / installments;
      return moneyFormat
        .replace('{{amount_no_decimals}}', Math.round(amount).toString())
        .replace('{{amount}}', amount.toFixed(2));
    }

    function updatePrice(cents) {
      if (!priceEl || !cents || cents <= 0) return;
      priceEl.textContent = formatMoney(cents);
    }

    function variantPriceById(id) {
      try {
        var variants = window.ShopifyAnalytics.meta.product.variants;
        for (var i = 0; i < variants.length; i++) {
          if (String(variants[i].id) === String(id)) return variants[i].price;
        }
      } catch (e) {}
      return null;
    }

    // Variant selector change (name="id" input)
    document.addEventListener('change', function (e) {
      if (!e.target || e.target.getAttribute('name') !== 'id') return;
      var price = variantPriceById(e.target.value);
      if (price) updatePrice(price);
    });

    // Theme custom events
    document.addEventListener('variant:changed', function (e) {
      if (e.detail && e.detail.variant) updatePrice(e.detail.variant.price);
    });
    document.addEventListener('variantChange', function (e) {
      if (e.detail && e.detail.variant) updatePrice(e.detail.variant.price);
    });

    updatePrice(parseInt(badge.dataset.initialPrice || '0', 10));
  })();
  </script>

{%- endif -%}

{% schema %}
{
  "name": "DML Shop Pay Badge A/B",
  "target": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Place this block below the Add to Cart button. Activate the test from the app dashboard."
    },
    {
      "type": "range",
      "id": "installments",
      "label": "Number of installments",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Shop Pay icon color",
      "default": "#5a31f4"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size (px)",
      "min": 11,
      "max": 18,
      "step": 1,
      "default": 14
    }
  ]
}
{% endschema %}
