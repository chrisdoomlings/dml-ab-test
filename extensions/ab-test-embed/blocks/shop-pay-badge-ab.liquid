{%- assign selected_variant = product.selected_or_first_available_variant -%}
{%- assign variant_price = selected_variant.price | default: 0 -%}
{%- assign installments = block.settings.installments | default: 4 -%}

{%- if product -%}
{%- assign target_handle = block.settings.target_product_handle | strip -%}
{%- if target_handle == blank or product.handle == target_handle -%}

<style>#dml-badge-a,#dml-badge-b{display:none}</style>

  <!-- Control (A): optional test label -->
  <div id="dml-badge-a" style="padding:10px 0;font-size:{{ block.settings.font_size }}px;color:{{ block.settings.text_color }};">{% if block.settings.show_no_badge_label %}No badge{% endif %}</div>

  <!-- Variant (B): Shop Pay installments badge -->
  <div
    id="dml-badge-b"
    data-installments="{{ installments }}"
    data-money-format="{{ shop.money_format | escape }}"
    data-initial-price="{{ variant_price }}"
    style="padding:10px 0;color:{{ block.settings.text_color }};font-size:{{ block.settings.font_size }}px;line-height:1.5;"
    {{ block.shopify_attributes }}
  >
    Available in <strong>{{ installments }}</strong> monthly payments of
    <strong class="dml-badge-install-price"></strong>
    through <strong>Shop Pay Installments</strong>
  </div>

  <script>
  (function () {
    var badge = document.getElementById('dml-badge-b');
    if (!badge) return;

    var installments = parseInt(badge.dataset.installments, 10) || 4;
    var moneyFormat = badge.dataset.moneyFormat;
    var priceEl = badge.querySelector('.dml-badge-install-price');
    var PAT_AMT = '{' + '{amount}}';
    var PAT_ND  = '{' + '{amount_no_decimals}}';

    function formatMoney(cents) {
      var amount = cents / 100 / installments;
      return (moneyFormat || '')
        .replace(PAT_ND, Math.round(amount).toString())
        .replace(PAT_AMT, amount.toFixed(2));
    }

    function updatePrice(cents) {
      if (!priceEl || !cents || cents <= 0) return;
      priceEl.innerHTML = formatMoney(cents);
    }

    function variantPriceById(id) {
      try {
        var variants = window.ShopifyAnalytics.meta.product.variants;
        for (var i = 0; i < variants.length; i++) {
          if (String(variants[i].id) === String(id)) return variants[i].price;
        }
      } catch (e) {}
      return null;
    }

    // Variant selector change (name="id" input)
    document.addEventListener('change', function (e) {
      if (!e.target || e.target.getAttribute('name') !== 'id') return;
      var price = variantPriceById(e.target.value);
      if (price) updatePrice(price);
    });

    // Theme custom events
    document.addEventListener('variant:changed', function (e) {
      if (e.detail && e.detail.variant) updatePrice(e.detail.variant.price);
    });
    document.addEventListener('variantChange', function (e) {
      if (e.detail && e.detail.variant) updatePrice(e.detail.variant.price);
    });

    updatePrice(parseInt(badge.dataset.initialPrice || '0', 10));
  })();
  </script>

{%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "DML Shop Pay Badge A/B",
  "target": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Place this block below the Add to Cart button. Activate the test from the app dashboard."
    },
    {
      "type": "checkbox",
      "id": "show_no_badge_label",
      "label": "Show 'No badge' label (testing only)",
      "default": false,
      "info": "Enable during testing to confirm variant A is working. Turn off before launch."
    },
    {
      "type": "text",
      "id": "target_product_handle",
      "label": "Target product handle",
      "placeholder": "e.g. my-product-name",
      "info": "Leave blank to show on all products. Enter a product handle to restrict to one product only."
    },
    {
      "type": "range",
      "id": "installments",
      "label": "Number of installments",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
{
      "type": "range",
      "id": "font_size",
      "label": "Font size (px)",
      "min": 11,
      "max": 18,
      "step": 1,
      "default": 14
    }
  ]
}
{% endschema %}
