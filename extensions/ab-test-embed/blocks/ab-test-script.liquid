{% schema %}
{
  "name": "DML AB Test Embed",
  "target": "body",
  "settings": [
    { "type": "text", "id": "app_base_url", "label": "App base URL", "default": "https://your-app-url" },
    { "type": "text", "id": "clarity_project_id", "label": "Microsoft Clarity project ID (optional)" }
  ]
}
{% endschema %}

<script>
  window.DML_AB_TEST = {
    appBaseUrl: "{{ block.settings.app_base_url | escape }}",
    shopDomain: "{{ shop.permanent_domain | escape }}",
    template: "{{ template.name | escape }}",
    clarityProjectId: "{{ block.settings.clarity_project_id | escape }}"
  };
</script>

{% if block.settings.clarity_project_id != blank %}
<script>
  (function(c,l,a,r,i,t,y){
    c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
    t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
    y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
  })(window,document,"clarity","script","{{ block.settings.clarity_project_id | escape }}");
</script>
{% endif %}
<script>
  (function () {
    try {
      var raw = localStorage.getItem("dml_ab_experiments");
      if (!raw) return;
      var cached = JSON.parse(raw);
      var payload = Array.isArray(cached)
        ? { pagePath: window.location.pathname, experiments: cached }
        : cached;
      if (!payload || payload.pagePath !== window.location.pathname) return;
      (payload.experiments || []).forEach(function (exp) {
        if (!exp || !exp.variants) return;
        var nodeA = document.querySelector(exp.variants.A);
        var nodeB = document.querySelector(exp.variants.B);
        if (!nodeA || !nodeB) return;
        var showA = exp.variant === "A";
        nodeA.style.display = showA ? "" : "none";
        nodeB.style.display = showA ? "none" : "";
      });
    } catch (e) {
      // noop
    }
  })();
</script>
<script src="{{ 'ab-test.js' | asset_url }}"></script>
