{% schema %}
{
  "name": "DML AB Test Placeholder",
  "target": "section",
  "settings": []
}
{% endschema %}

{{- "" -}}
<!--
  DML AB Test — control placeholder.
  This block is intentionally empty. Add it to the same section as your
  variant block so the A/B script has a valid nodeA element to toggle.
  It renders nothing and takes up no space on the page.
-->
<span
  id="dml-ab-placeholder-{{ block.id }}"
  style="display:none;width:0;height:0;overflow:hidden"
  aria-hidden="true"
  {{ block.shopify_attributes }}
></span>
